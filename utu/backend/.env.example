# =====================================================================
# UTU · environment configuration
# Copy this file to ".env" and fill in your real values.
# Never commit .env to git.
# =====================================================================

# Server
PORT=4000
NODE_ENV=production

# Owner / lead destination
OWNER_NAME=Ayoa Naser
OWNER_EMAIL=ayoa.naser96@gmail.com
OWNER_WHATSAPP=07838896681
# Country code form (no leading zero, no spaces) — used for wa.me links
OWNER_WHATSAPP_INTL=9647838896681

# CORS — comma-separated origins allowed to hit the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://utu.studio

# SMTP — for sending lead notification emails
# Use Gmail with an App Password (recommended for ayoa.naser96@gmail.com):
# 1. Turn on 2-factor auth on the Google account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Paste the 16-char password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ayoa.naser96@gmail.com
SMTP_PASS=your_16_char_app_password_here
SMTP_FROM="Utu Studio <ayoa.naser96@gmail.com>"

# Optional: rate limit window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
